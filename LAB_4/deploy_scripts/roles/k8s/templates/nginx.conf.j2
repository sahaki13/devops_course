error_log stderr notice;

worker_processes 2;
worker_rlimit_nofile 130048;
worker_shutdown_timeout 10s;

events {
  multi_accept on;
  use epoll;
  worker_connections 16384;
}

stream {
  upstream kube_apiserver {
    least_conn;
    {% for host in groups['dev_master_nodes'] -%}
    server {{ hostvars[host]['ansible_host'] }}:6443;
    {% endfor -%}
  }

  server {
    listen        127.0.0.1:3333;
    proxy_pass    kube_apiserver;
    proxy_timeout 10m;
    proxy_connect_timeout 1s;
  }
}

http {
  aio threads;
  aio_write on;
  tcp_nopush on;
  tcp_nodelay on;

  keepalive_timeout  5;
  keepalive_requests 100;
  reset_timedout_connection on;
  server_tokens off;
  autoindex off;

  # Healthcheck.
  ########################################################################
  server {
     listen 81;
     listen [::]:81;
     server_name  localhost;

     location /ping {
         add_header Content-Type text/html;
         access_log off;
         return 200 '<html><body>pong</body></html>';
     }
  }
  # default catchall block. ( intercept all wrong  url request )
  ########################################################################

  server {
     listen 80 default_server;
     server_name _;

     # deny all
     location / {
         ### allow to display inline html within browsers
         add_header Content-Type text/html;
         types {}
         default_type text/html;
         #####
         return 503 '<html><body>Service $request_uri NOT available.</body></html>';
     }
  }
}
