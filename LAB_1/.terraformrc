provider_installation {
  dev_overrides {
    # "registry.terraform.io/dmacvicar/libvirt" = "$HOME/.terraform.d/plugins/registry.terraform.io/dmacvicar/libvirt/dev/linux_amd64"
    # "registry.terraform.io/dmacvicar/libvirt" = "$HOME/.terraform.d/plugins/registry.terraform.io/dmacvicar/libvirt/0.8.3/linux_amd64"
    "registry.terraform.io/dmacvicar/libvirt" = "$HOME/.terraform.d/plugins/registry.terraform.io/dmacvicar/libvirt/0.9.2/linux_amd64"
  }

  # For all other providers, install them directly from their origin provider
  # registries as normal.
  direct {}
}
